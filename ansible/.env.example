# ── x86 Linux (used by Ansible) ──
X86_HOST=192.168.1.100
X86_USER=ubuntu

# ── Backup (external SSD path, mounted on Mac) ──
BACKUP_PATH=/Volumes/BackupSSD/multiarch-backup

# ── Docker Hub (login manually pre-demo) ──
DOCKER_USER=yourdockerhub
DOCKER_IMAGE=yourdockerhub/multiarch-demo

# ── Tart VM (for demo script) ──
TART_VM_NAME=ubuntu-arm
TART_VM_USER=ubuntu

# ── Repo to build ──
REPO_PATH=../my-node-app
